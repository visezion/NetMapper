FROM netboxcommunity/netbox:v4.6

COPY docker/plugin_requirements.txt /tmp/plugin_requirements.txt
COPY . /opt/netbox/netdoc-source
RUN apt-get update
RUN apt-get -y install git
RUN git clone --depth=1 https://github.com/networktocode/ntc-templates /opt/ntc-templates
RUN /opt/netbox/venv/bin/pip install --no-warn-script-location -r /tmp/plugin_requirements.txt
RUN /opt/netbox/venv/bin/pip uninstall -y netdoc || true
RUN find /opt/netbox/venv/lib -path "*/site-packages/netdoc*" -exec rm -rf {} +
RUN find /opt/netbox/venv/lib -path "*/site-packages/__editable__.*netdoc*" -delete
RUN find /opt/netbox/venv/lib -path "*/site-packages/netdoc.egg-link" -delete
RUN /opt/netbox/venv/bin/pip install --no-warn-script-location --no-deps /opt/netbox/netdoc-source
RUN /opt/netbox/venv/bin/python -c "import pathlib, netdoc; print(netdoc.__file__); source = pathlib.Path(netdoc.__file__).read_text(); assert 'getattr(extras_models, \"ReportModule\", None)' in source, netdoc.__file__"

# These lines are only required if your plugin has its own static files.
COPY docker/configuration/configuration.py /etc/netbox/config/configuration.py
RUN SECRET_KEY="dummydummydummydummydummydummydummydummydummydummy" /opt/netbox/venv/bin/python /opt/netbox/netbox/manage.py collectstatic --no-input
